          "meta": { "builderOptions": { "columns": [], "database": "", "limit": 1000, "mode": "list", "queryType": "table", "table": "" } },
          "pluginVersion": "4.17.0", "queryType": "timeseries",
          "rawSql": "SELECT\n    toStartOfInterval(TimeUnix, INTERVAL 30 SECOND) AS time,\n    Attributes['state'] AS state,\n    (max(toFloat64(Value)) - min(toFloat64(Value))) / 30.0 AS cpu_seconds_per_sec\nFROM otel.otel_metrics_sum\nWHERE $__timeFilter(TimeUnix)\n  AND MetricName = 'process.cpu.time'\n  AND ResourceAttributes['process.executable.name'] = 'pgprism'\nGROUP BY time, state\nORDER BY time ASC, state ASC",
          "refId": "A"
        }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
